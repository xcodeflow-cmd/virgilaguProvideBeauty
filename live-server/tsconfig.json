{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node", "ws"]
  },
  "include": [
    "./index.ts",
    "../lib/live-config.ts",
    "../lib/live-token.ts",
    "../types/live-media.ts"
  ]
}
